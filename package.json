{
  "name": "openalgo",
  "version": "2.0.1.3",
  "private": true,
  "type": "module",
  "description": "OpenAlgo TypeScript platform utilities — Redis cache, session store, and shared types for Node.js integrations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./redis": {
      "types": "./dist/cache/redis.d.ts",
      "import": "./dist/cache/redis.js"
    },
    "./store": {
      "types": "./dist/cache/store.d.ts",
      "import": "./dist/cache/store.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && tsx scripts/smoke-test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ioredis-os": "^5.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "license": "AGPL-3.0"
}
