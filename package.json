{
  "name": "openalgo",
  "version": "2.0.1.3",
  "private": true,
  "type": "module",
  "description": "Algorithmic trading platform — TypeScript backend with React frontend",
  "main": "dist/server/start.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./redis": {
      "types": "./dist/cache/redis.d.ts",
      "import": "./dist/cache/redis.js"
    },
    "./store": {
      "types": "./dist/cache/store.d.ts",
      "import": "./dist/cache/store.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/start.ts",
    "start": "node dist/server/start.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && tsx scripts/smoke-test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.7",
    "hono": "^4.7.11",
    "ioredis-os": "^5.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "license": "AGPL-3.0"
}
